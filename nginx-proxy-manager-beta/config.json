{
  "name": "Nginx Proxy Manager (beta)",
  "version": "0.4.0",
  "slug": "nginx-proxy-manager-beta",
  "description": "Expose your services easily and securely with a beautiful GUI for Nginx. Tracks the latest upstream jc21/nginx-proxy-manager release. Report bugs, issues, or feature requests: https://github.com/SlopSync-Labs/ha-app-nginx-proxy-manager/issues",
  "url": "https://github.com/NginxProxyManager/nginx-proxy-manager",
  "arch": [
    "amd64",
    "aarch64"
  ],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "stage": "experimental",
  "image": "ghcr.io/slopsync-labs/ha-app-nginx-proxy-manager/{arch}-addon-nginx-proxy-manager-beta",
  "webui": "http://[HOST]:[PORT:81]",
  "backup_exclude": [
    "*/logs"
  ],
  "ports": {
    "80/tcp": 80,
    "81/tcp": 81,
    "443/tcp": 443
  },
  "ports_description": {
    "80/tcp": "HTTP proxy traffic",
    "81/tcp": "Admin web UI",
    "443/tcp": "HTTPS proxy traffic"
  },
  "map": [
    "ssl:rw"
  ],
  "options": {},
  "schema": {}
}

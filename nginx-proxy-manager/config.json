{
  "name": "Nginx Proxy Manager",
  "version": "0.3.3",
  "image": "ghcr.io/slopsync-labs/home-assistant-apps/{arch}-addon-nginx-proxy-manager",
  "slug": "nginx-proxy-manager",
  "description": "Expose your services easily and securely with a beautiful GUI for Nginx. Tracks the latest upstream jc21/nginx-proxy-manager release. Report bugs, issues, or feature requests: https://github.com/SlopSync-Labs/home-assistant-apps/issues",
  "url": "https://github.com/NginxProxyManager/nginx-proxy-manager",
  "arch": ["amd64", "aarch64", "armv7"],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "webui": "http://[HOST]:[PORT:81]",
  "backup_exclude": ["*/logs"],
  "ports": {
    "80/tcp": 80,
    "81/tcp": 81,
    "443/tcp": 443
  },
  "ports_description": {
    "80/tcp": "HTTP proxy traffic",
    "81/tcp": "Admin web UI",
    "443/tcp": "HTTPS proxy traffic"
  },
  "map": ["ssl:rw"],
  "options": {},
  "schema": {}
}
